---
import BaseLayout from "../layouts/BaseLayout.astro";

const sections = [
  { id: "about", label: "About", index: "01" },
  { id: "skills", label: "Skills", index: "02" },
  { id: "projects", label: "Projects", index: "03" },
  { id: "work", label: "Work", index: "04" },
  { id: "contact", label: "Contact", index: "05" }
];

const projects = [
  {
    title: "Personal Website",
    description:
      "Built with Astro and Tailwind to showcase projects, experience, and contact details in a fast, responsive portfolio.",
    media: "/projects/personal-website.png",
    alt: "Screenshot of the personal website project",
    github: "https://github.com/carterrows/personal-site"
  },
  {
    title: "Budget Tool",
    description:
      "Self-hosted budgeting app with secure authentication, multi-plan workflows, autosave, and monthly cash-flow projections.",
    media: "/projects/budget-tool.gif",
    alt: "Demo of the budget tool project",
    github: "https://github.com/carterrows/budget-tool"
  },
  {
    title: "Sweetside Website",
    description:
      "Responsive site for a local band with reusable UI components and a JSON-driven content system for shows, media, and member info.",
    media: "/projects/sweetside-website.gif",
    alt: "Demo of the Sweetside website project",
    github: "https://github.com/carterrows/sweetsideband-site"
  },
  {
    title: "RPI Stats",
    description:
      "Lightweight FastAPI and Tailwind dashboard for live Raspberry Pi CPU temperature and fan monitoring with on-demand polling.",
    media: "/projects/rpi-stats.png",
    alt: "Screenshot of the RPI stats dashboard project",
    github: "https://github.com/carterrows/rpi-stats"
  }
];
---

<BaseLayout title="Carter Rows | Technology Analyst" name="Carter Rows">
  <aside class="dot-nav" aria-label="Section navigation">
    {
      sections.map((section) => (
        <a
          class="dot-link"
          data-dot-target={section.id}
          href={`#${section.id}`}
          aria-label={section.label}
        />
      ))
    }
  </aside>

  <section id="about" class="section-panel border-t border-[color:var(--line)]">
    <div class="section-shell about-shell">
      <div class="about-copy">
        <p class="section-index">{sections[0].index}</p>
        <h1 class="section-title">Computer engineer building AI-driven solutions to complex problems.</h1>
        <p class="section-copy">
          I am a computer engineer who enjoys turning ideas into practical products people can use.
          I spend most of my time building web apps, automation, and cloud workflows, and I use AI
          agents like Codex to move from concept to shipped features faster. I care about clean
          implementation, reliable systems, and continuously improving by building.
        </p>
      </div>
      <div class="about-photo-frame">
        <img
          class="about-photo"
          src="/images/profile.jpeg"
          alt="carter-rows"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <section id="skills" class="section-panel">
    <div class="section-shell">
      <p class="section-index">{sections[1].index}</p>
      <h2 class="section-title">Skills</h2>
      <ul class="chip-grid">
        <li class="chip">Next.js</li>
        <li class="chip">React</li>
        <li class="chip">TypeScript/JavaScript</li>
        <li class="chip">Python</li>
        <li class="chip">C</li>
        <li class="chip">Java</li>
        <li class="chip">HTML/CSS</li>
        <li class="chip">SQL</li>
        <li class="chip">Docker</li>
        <li class="chip">AWS</li>
        <li class="chip">Azure</li>
        <li class="chip">Git</li>
        <li class="chip">Agile Development</li>
        <li class="chip">Jira</li>
      </ul>
    </div>
  </section>

  <section id="projects" class="section-panel">
    <div class="section-shell">
      <p class="section-index">{sections[2].index}</p>
      <h2 class="section-title">Projects</h2>
      <div class="project-grid">
        {
          projects.map((project) => (
            <article class="project-card">
              <img
                class="project-media"
                src={project.media}
                alt={project.alt}
                loading="lazy"
                decoding="async"
              />
              <div class="project-content">
                <h3 class="card-title">{project.title}</h3>
                <p class="section-copy project-description">{project.description}</p>
                <a
                  class="project-github"
                  href={project.github}
                  rel="noreferrer"
                  target="_blank"
                  aria-label={`View ${project.title} on GitHub`}
                >
                  <img class="project-github-icon" src="/icons/github.svg" alt="" loading="lazy" />
                  <span>GitHub</span>
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section id="work" class="section-panel">
    <div class="section-shell">
      <p class="section-index">{sections[3].index}</p>
      <h2 class="section-title">Work</h2>
      <div class="card-stack">
        <article class="info-card">
          <div class="work-head">
            <img class="work-logo" src="/images/accenture.png" alt="Accenture logo" loading="lazy" />
            <div>
              <h3 class="card-title">Accenture</h3>
              <p class="work-role">Technology Summer Analyst</p>
              <p class="work-meta">Toronto, ON</p>
              <p class="work-meta">June 2025 - Aug 2025</p>
            </div>
          </div>
          <p class="section-copy">
            Worked on cloud-cost optimization initiatives across Azure environments by improving
            monitoring strategy, automating resource audits, and building Power BI reporting that
            made spend trends and savings opportunities easier for teams to act on.
          </p>
        </article>
        <article class="info-card">
          <div class="work-head">
            <img class="work-logo" src="/images/hdsb.png" alt="Halton District School Board logo" loading="lazy" />
            <div>
              <h3 class="card-title">Halton District School Board</h3>
              <p class="work-role">Network Operations</p>
              <p class="work-meta">Burlington, ON</p>
              <p class="work-meta">May 2023 - Sept 2024</p>
            </div>
          </div>
          <p class="section-copy">
            Supported network operations across 100+ schools by deploying and troubleshooting core
            infrastructure, resolving device-level issues, and producing clear topology
            documentation that improved reliability and day-to-day maintenance.
          </p>
        </article>
      </div>
    </div>
  </section>

  <section id="contact" class="section-panel">
    <div class="section-shell">
      <p class="section-index">{sections[4].index}</p>
      <h2 class="section-title">Contact</h2>
      <p class="section-copy">carter.rows@gmail.com</p>
      <div class="link-row">
        <a class="icon-link" href="mailto:carter.rows@gmail.com" aria-label="Email">
          <img class="contact-icon" src="/icons/email.svg" alt="" loading="lazy" />
        </a>
        <a class="icon-link" href="https://linkedin.com/in/carter-rows" rel="noreferrer" target="_blank" aria-label="LinkedIn">
          <img class="contact-icon" src="/icons/linkedin.svg" alt="" loading="lazy" />
        </a>
        <a class="icon-link" href="https://github.com/carterrows" rel="noreferrer" target="_blank" aria-label="GitHub">
          <img class="contact-icon" src="/icons/github.svg" alt="" loading="lazy" />
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    (() => {
      const sectionIds = ["about", "skills", "projects", "work", "contact"];
      const sections = sectionIds
        .map((id) => document.getElementById(id))
        .filter((section) => section instanceof HTMLElement);

      if (sections.length === 0) return;

      const navLinks = Array.from(document.querySelectorAll("[data-nav-target]"));
      const dotLinks = Array.from(document.querySelectorAll("[data-dot-target]"));
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      let activeIndex = -1;
      let isAnimating = false;
      let releaseTimer = 0;
      let frame = 0;
      let lockedIndex = null;
      let lockReleaseTimer = 0;

      const getActiveSectionIndex = () => {
        const viewportCenter = window.innerHeight * 0.5;
        let fallbackIndex = 0;
        let fallbackDistance = Number.POSITIVE_INFINITY;

        for (let index = 0; index < sections.length; index += 1) {
          const rect = sections[index].getBoundingClientRect();
          if (rect.top <= viewportCenter && rect.bottom >= viewportCenter) {
            return index;
          }

          const sectionCenter = rect.top + rect.height * 0.5;
          const distance = Math.abs(sectionCenter - viewportCenter);
          if (distance < fallbackDistance) {
            fallbackDistance = distance;
            fallbackIndex = index;
          }
        }

        return fallbackIndex;
      };

      const setActiveSection = (index) => {
        if (index === activeIndex) return;
        activeIndex = index;
        const activeId = sectionIds[index];

        navLinks.forEach((link) => {
          const isActive = link.getAttribute("data-nav-target") === activeId;
          link.classList.toggle("is-active", isActive);
          if (isActive) {
            link.setAttribute("aria-current", "page");
          } else {
            link.removeAttribute("aria-current");
          }
        });

        dotLinks.forEach((link) => {
          const isActive = link.getAttribute("data-dot-target") === activeId;
          link.classList.toggle("is-active", isActive);
          link.setAttribute("aria-current", isActive ? "true" : "false");
        });
      };

      const goToSection = (index) => {
        if (index < 0 || index >= sections.length) return;
        lockedIndex = index;
        window.clearTimeout(lockReleaseTimer);
        lockReleaseTimer = window.setTimeout(() => {
          lockedIndex = null;
        }, reducedMotion ? 240 : 1000);

        sections[index].scrollIntoView({
          behavior: reducedMotion ? "auto" : "smooth",
          block: "start"
        });
        setActiveSection(index);
      };

      const linkToSection = (event, attribute) => {
        const target = event.currentTarget;
        if (!(target instanceof HTMLElement)) return;
        event.preventDefault();
        const sectionId = target.getAttribute(attribute);
        if (!sectionId) return;
        const targetIndex = sectionIds.indexOf(sectionId);
        if (targetIndex < 0) return;
        goToSection(targetIndex);
      };

      navLinks.forEach((link) => {
        link.addEventListener("click", (event) => linkToSection(event, "data-nav-target"));
      });

      dotLinks.forEach((link) => {
        link.addEventListener("click", (event) => linkToSection(event, "data-dot-target"));
      });

      window.addEventListener(
        "scroll",
        () => {
          if (frame) return;
          frame = window.requestAnimationFrame(() => {
            if (lockedIndex !== null) {
              const targetRect = sections[lockedIndex].getBoundingClientRect();
              const viewportCenter = window.innerHeight * 0.5;
              const targetIsCentered =
                targetRect.top <= viewportCenter && targetRect.bottom >= viewportCenter;

              if (targetIsCentered) {
                setActiveSection(lockedIndex);
                lockedIndex = null;
                window.clearTimeout(lockReleaseTimer);
              }
            } else {
              setActiveSection(getActiveSectionIndex());
            }
            frame = 0;
          });
        },
        { passive: true }
      );

      window.addEventListener(
        "wheel",
        (event) => {
          if (event.ctrlKey || event.metaKey || event.shiftKey) return;
          if (Math.abs(event.deltaY) < 8) return;
          event.preventDefault();

          if (isAnimating) return;

          const currentIndex = getActiveSectionIndex();
          const direction = event.deltaY > 0 ? 1 : -1;
          const targetIndex = Math.min(
            sections.length - 1,
            Math.max(0, currentIndex + direction)
          );

          if (targetIndex === currentIndex) return;

          isAnimating = true;
          goToSection(targetIndex);
          window.clearTimeout(releaseTimer);
          releaseTimer = window.setTimeout(() => {
            isAnimating = false;
          }, reducedMotion ? 160 : 700);
        },
        { passive: false }
      );

      setActiveSection(getActiveSectionIndex());
    })();
  </script>
</BaseLayout>
