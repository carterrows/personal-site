---
import "../styles/global.css";

interface Props {
  title?: string;
  name?: string;
}

const { title = "Personal Site", name = "Your Name" } = Astro.props;

const navItems = [
  { id: "about", label: "About" },
  { id: "skills", label: "Skills" },
  { id: "projects", label: "Projects" },
  { id: "work", label: "Work" },
  { id: "contact", label: "Contact" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="site-body antialiased">
    <header class="fixed inset-x-0 top-0 z-50 border-b border-[color:var(--line)] bg-[color:var(--surface)]/95 backdrop-blur">
      <nav class="mx-auto flex h-20 w-full max-w-6xl items-center gap-4 px-4 sm:px-6">
        <a
          href="#about"
          class="whitespace-nowrap text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--ink)] sm:text-sm"
        >
          {name}
        </a>
        <ul class="ml-auto flex min-w-0 flex-1 items-center justify-end gap-1 overflow-x-auto pb-1 text-[10px] font-medium uppercase tracking-[0.12em] sm:gap-2 sm:text-xs">
          {
            navItems.map((item) => (
              <li>
                <a class="top-link" data-nav-target={item.id} href={`#${item.id}`}>
                  {item.label}
                </a>
              </li>
            ))
          }
          <li>
            <a class="resume-link" href="/resume.pdf" download>
              Resume
            </a>
          </li>
        </ul>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl px-4 sm:px-6">
      <slot />
    </main>
  </body>
</html>
