---
import "../styles/global.css";

interface Props {
  title?: string;
  name?: string;
}

const { title = "Personal Site", name = "Your Name" } = Astro.props;

const navItems = [
  { id: "about", label: "About" },
  { id: "skills", label: "Skills" },
  { id: "projects", label: "Projects" },
  { id: "work", label: "Work" },
  { id: "contact", label: "Contact" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=arrow_back_ios,arrow_forward_ios,dehaze" />
  </head>
  <body class="site-body antialiased">
    <header class="site-header fixed inset-x-0 top-0 z-50 border-b border-[color:var(--line)] bg-[color:var(--surface)]/95 backdrop-blur">
      <nav class="site-nav mx-auto w-full max-w-6xl px-4 sm:px-6">
        <div class="site-nav-main">
          <a
            href="#about"
            class="whitespace-nowrap text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--ink)] sm:text-sm"
          >
            {name}
          </a>

          <ul class="ml-auto hidden min-w-0 flex-1 items-center justify-end gap-1 overflow-x-auto pb-1 text-[10px] font-medium uppercase tracking-[0.12em] sm:flex sm:gap-2 sm:text-xs">
            {
              navItems.map((item) => (
                <li>
                  <a class="top-link" data-nav-target={item.id} href={`#${item.id}`}>
                    {item.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a class="resume-link" href="/api/resume">
                Resume
              </a>
            </li>
          </ul>

          <button
            type="button"
            class="mobile-menu-toggle ml-auto sm:hidden"
            data-mobile-nav-toggle
            aria-controls="mobile-nav"
            aria-expanded="false"
            aria-label="Open section navigation"
          >
            <span class="material-symbols-outlined" aria-hidden="true">dehaze</span>
          </button>
        </div>
        <div id="mobile-nav" class="mobile-nav-popup sm:hidden" data-mobile-nav hidden>
          <ul class="mobile-nav-list" aria-label="Mobile section navigation">
            {
              navItems.map((item) => (
                <li>
                  <a class="mobile-nav-link" data-nav-target={item.id} href={`#${item.id}`}>
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </header>
    <main class="mx-auto max-w-6xl px-4 sm:px-6">
      <slot />
    </main>
  </body>
</html>
